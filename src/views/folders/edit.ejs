<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update</title>
  </head>
  <body>
    <%-include("../partials/_nav") %>
    <h1>
      Update folder
      <%= folder.name %>
    </h1>
    <form action="/folders/update/<%= folder.id %>" method="POST">
      <label for="name">Name:</label>
      <input type="text" id="name" name="name" value="<%= folder.name %>" />
      <button type="submit">Update</button>
    </form>
  </body>
</html>
