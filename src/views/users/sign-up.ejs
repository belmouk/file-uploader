<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign Up</title>
  </head>
  <body>
    <%-include("../partials/_nav") %>

    <h1>Sign Up</h1>
    <% if(errors.length > 0) { %>
    <ul>
      <% {errors.forEach(error => { %>
      <li><%= error.msg %></li>
      <% })} %>
    </ul>
    <% } %>
    <%- include("../partials/_form", {action: {text: "Sign up", path:"/users/store" } , link: {text: "Log in", href:"/log-in"}}) %>
  </body>
</html>
